<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>

<!-- Generates a .zip file with all required files for publishing -->
<Project>
    <ItemGroup>
        <PackageFiles Include="$(PackageDir)\*.*" />
    </ItemGroup>

    <!-- Copy files to temporary folder before compressing into .zip -->
    <Target Name="CopyToPackage" AfterTargets="Build">
        <Message Text="Copying files into tmp directory" Importance="high" />
        <PropertyGroup>
            <ReadmeFile>$(RootPath)\README.md</ReadmeFile>
            <LicenseFile>$(RootPath)\LICENSE</LicenseFile>
        </PropertyGroup>
        <MakeDir Directories="$(TmpDir)" />
        <!-- Copy README.md, LICENSE and resulting .dll file -->
        <Copy
            SourceFiles="$(ReadmeFile)"
            DestinationFolder="$(TmpDir)"
            SkipUnchangedFiles="true" />
        <Copy
            SourceFiles="$(LicenseFile)"
            DestinationFolder="$(TmpDir)"
            SkipUnchangedFiles="true" />
        <Copy
            SourceFiles="$(TargetPath)"
            DestinationFolder="$(TmpDir)"
            SkipUnchangedFiles="true" />
        <!-- Copies files in package folder -->
        <Copy
            SourceFiles="@(PackageFiles)"
            DestinationFolder="$(TmpDir)"
            SkipUnchangedFiles="True" />
    </Target>

    <!-- Zip files for publishing -->
    <Target Name="ZipPackage" AfterTargets="CopyToPackage">
        <PropertyGroup>
            <ZipPath>$(ProjectDir)\$(AssemblyName).zip</ZipPath>
        </PropertyGroup>
        <!-- Remove existing zip -->
        <Delete Files="$(ZipPath)" Condition="Exists('$(ZipPath)')" />
        <!-- Create zip -->
        <ZipDirectory
            SourceDirectory="$(TmpDir)\"
            DestinationFile="$(ZipPath)" />
    </Target>

    <!-- Clean temporary folder -->
    <Target Name="CleanPackage" AfterTargets="ZipPackage">
        <Message Text="Cleaning up tmp directory" Importance="high" />
        <RemoveDir Directories="$(TmpDir)\" />
    </Target>
</Project>